{
  "expo": {
    "name": "finanzas-app",
    "slug": "finanzas-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "finanzasapp",
    "userInterfaceStyle": "automatic",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#ffffff"
      },
      "package": "com.maneax.finanzasapp"
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-sqlite",
      "expo-asset"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "0420ae1e-2ef4-4749-ba03-dd16d149b10e"
      }
    },
    "owner": "maneax"
  }
}
